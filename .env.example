# ──────────────────────────────────────────────
# LeadHaus AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# Porta do servidor (padrão: 3000)
PORT=3000

# ── WhatsApp Cloud API (Meta) ──────────────────
# Token permanente gerado no painel da Meta for Developers
WHATSAPP_TOKEN=seu_token_permanente_aqui

# ID do número de telefone (Phone Number ID) — não é o número em si
WHATSAPP_PHONE_ID=seu_phone_number_id_aqui

# Token customizado para verificar o webhook (você define este valor)
WEBHOOK_VERIFY_TOKEN=leadhaus_verify_2024

# Número do corretor para receber notificações de leads quentes
# Formato: código do país + DDD + número (sem + ou espaços)
CORRETOR_TELEFONE=5583999999999

# ── Anthropic (Claude) ────────────────────────
# Chave de API do Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets ─────────────────────────────
# ID da planilha (encontrado na URL: /spreadsheets/d/[ID]/edit)
GOOGLE_SHEET_ID=seu_sheet_id_aqui

# Nome da aba onde os leads serão salvos (padrão: Leads)
GOOGLE_SHEET_ABA=Leads

# Credenciais da Service Account em formato JSON (em uma única linha)
# Gere em: Google Cloud Console > IAM > Service Accounts > Chaves
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
